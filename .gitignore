# Local configuration overrides
config.env
.scan-tools

# Build and install artefacts
/build/
/vendor/touchstone/
/third_party/

# Benchmark output (keep the directory via .gitkeep)
/results/*
!/results/.gitkeep
!/results/latest/
!/results/latest/**

# Profile runtime caches (committed: manifest, raw/, enforced/)
profiles/*/rootfs/
profiles/*/runs/
profiles/*/config.json
profiles/*/config.raw.json
profiles/*/generated/

# Legacy generated bundles
/bundles/scanned/

# Host-specific containerd backups
/config/containerd.config.toml.bak
/config/containerd.config.toml.pristine

# Copy to config.env and adjust for your benchmark host.
# All scripts source this file when present.

# --- Runtime binaries ---
RUNC_STOCK_REF=main
RUNC_STOCK_BIN=/usr/local/sbin/runc-stock
RUNC_HARDENED_BIN=/usr/local/sbin/runc-hardened

# Path to hardened runc source tree. When empty, setup clones github.com/dpttk/runc.
HARDENED_RUNC_SRC=

BUILD_DIR=/tmp/performance-eval-build
GO_VERSION=1.22.4

# --- containerd / CRI ---
CONTAINERD_CONFIG=/etc/containerd/config.toml
CONTAINERD_SOCKET=/run/containerd/containerd.sock
CONTAINERD_NAMESPACE=performance-eval

# CRI handler names registered in containerd (for Touchstone / crictl).
RUNTIME_STOCK=runc
RUNTIME_HARDENED=runc-hardened
RUNTIME_GVISOR=runsc

# Values passed to `ctr run --runtime` on containerd 2.x.
# Full OCI binary paths work for all three runtimes; no CRI config patching needed.
CTR_RUNTIME_STOCK=/usr/local/sbin/runc-stock
CTR_RUNTIME_HARDENED=/usr/local/sbin/runc-hardened
CTR_RUNTIME_GVISOR=/usr/local/bin/runsc

# --- gVisor ---
# Latest stable tag from https://github.com/google/gvisor/releases
GVISOR_RELEASE=20250319.0
RUNSC_BIN=/usr/local/bin/runsc

# --- Touchstone ---
TOUCHSTONE_REPO=https://github.com/lnsp/touchstone.git
TOUCHSTONE_REF=master
TOUCHSTONE_BIN=/usr/local/bin/touchstone
TOUCHSTONE_BUILD_DIR=/tmp/performance-eval-build/touchstone

# --- Docker (industry-default posture baseline) ---
# Docker Engine uses runc under the hood plus its own default seccomp/AppArmor
# profiles. It represents the "out of the box" security posture in comparisons.
DOCKER_BIN=/usr/bin/docker
# Optional: also register runsc and runc-hardened as Docker runtimes so Docker
# can be used as a cross-check launcher. 1 = patch /etc/docker/daemon.json.
DOCKER_REGISTER_EXTRA_RUNTIMES=1

# --- Kata (deferred on hosts without /dev/kvm) ---
# This VM has no nested virtualization, so Kata is skipped by default. Set to 1
# only on a bare-metal / nested-KVM host where containerd-shim-kata-v2 exists.
KATA_ENABLE=0
KATA_RUNTIME=io.containerd.kata.v2

# --- Benchmark parameters ---
BENCHMARK_RUNS=10
STARTUP_ITERATIONS=100
SCALABILITY_SIZES="5 10 50"
RESULTS_DIR=./results

# Runtimes exercised by the performance + security suites (space separated).
# Valid aliases: stock hardened gvisor docker kata
RUNTIMES="stock hardened gvisor docker"

# --- Statistical rigor ---
# Each latency/app metric is sampled REPS times after WARMUP discarded samples.
# Reported as median / p95 / p99 / stddev rather than a single mean.
WARMUP=5
REPS=30
# Density / scalability parallel container counts.
DENSITY_SIZES="5 10 25 50 75"
# Pin CPU governor to performance and capture turbo state for methodology notes.
PIN_CPU_GOVERNOR=1
# Optional CPU core list to pin workloads to (taskset -c). Empty = no pinning.
PIN_CPU_CORES=

# --- Disk I/O (fio) ---
FIO_SIZE=512M
FIO_RUNTIME=15
FIO_BS=4k
FIO_IODEPTH=16

# --- Network (iperf3) ---
IPERF_DURATION=10
IPERF_PARALLEL=1

# --- Application workloads ---
# nginx + wrk (HTTP throughput/latency) and redis-benchmark (syscall-heavy).
WRK_DURATION=15
WRK_THREADS=2
WRK_CONNECTIONS=50
REDIS_BENCH_REQUESTS=100000
REDIS_BENCH_CLIENTS=50
REDIS_BENCH_PIPELINE=1

# --- Security profile generation / scan ---
# Source tree of dpttk/runc (for --security-scan). Empty = use HARDENED_RUNC_SRC.
SCAN_RUNC_SRC=
# Directory where generated per-workload OCI bundles are stored.
SCAN_BUNDLES_DIR=./bundles/scanned
# Non-root uid/gid used during scans (matches dpttk/runc setup-scan-host.sh).
SCAN_UID=65532
SCAN_GID=65532

# --- Security attack matrix ---
# Image used for the generic post-RCE probe battery.
PROBE_IMAGE=docker.io/library/busybox:latest
# Optional vulnerable Flask app bundle (from runc-hardened-test) for the
# realistic post-RCE scenario. Empty = use the generic probe battery only.
VULN_APP_BUNDLE=

# --- Reporting ---
# Generate matplotlib plots in addition to CSV + Markdown tables (needs python3
# matplotlib; degrades gracefully to tables only when unavailable).
GENERATE_PLOTS=1

# --- Workloads ---
BUSYBOX_IMAGE=docker.io/library/busybox:latest
NGINX_IMAGE=docker.io/library/nginx:1.27-alpine
REDIS_IMAGE=docker.io/library/redis:7-alpine
SYSBENCH_IMAGE=docker.io/severalnines/sysbench:latest

# --- Hardened bundle (optional) ---
# Point to a scanned OCI bundle from the runtime security lab when measuring
# enforcement-mode overhead with generated seccomp/AppArmor/capability profiles.
HARDENED_BUNDLE_DIR=

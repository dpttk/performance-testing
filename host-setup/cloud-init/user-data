#cloud-config
hostname: perf-bench
manage_etc_hosts: true
package_update: true
package_upgrade: false

users:
  - name: benchmark
    gecos: Benchmark User
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    plain_text_passwd: benchmark
    ssh_authorized_keys:
      - ssh-rsa  plato@bmo

packages:
  - git
  - curl
  - ca-certificates

write_files:
  - path: /usr/local/sbin/run-benchmark-suite.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      LOG=/var/log/benchmark-suite.log
      exec > >(tee -a "$LOG") 2>&1
      echo "=== benchmark suite start $(date -Is) ==="
      REPO=/opt/performance-evaluation
      if [[ ! -d "$REPO/.git" ]]; then
        git clone https://github.com/dpttk/performance-testing.git "$REPO"
      else
        git -C "$REPO" pull --ff-only || true
      fi
      cd "$REPO"
      cp -n config.env.example config.env || true
      ./scripts/setup.sh
      ./scripts/prepare-profiles.sh
      ./scripts/run.sh
      echo "=== benchmark suite done $(date -Is) ==="

runcmd:
  - systemctl enable --now ssh
  - touch /var/log/benchmark-suite.log
  - echo "cloud-init complete" > /var/log/cloud-init-benchmark.done
